# ────────────────────────────────────────────────────────────
#  gumes marketplace — env pour les tests d'intégration
#  Chargé par `npm test` via dotenv-cli.
# ────────────────────────────────────────────────────────────

NODE_ENV=test
PORT=3001
PUBLIC_URL=http://localhost:3001

# DB dédiée sur le même conteneur Postgres que le dev.
DATABASE_URL=postgres://gumes:change-me-in-local@localhost:5432/gumes_marketplace_test
# Connexion admin (DB 'postgres') pour DROP/CREATE du DB de test.
DATABASE_URL_ADMIN=postgres://gumes:change-me-in-local@localhost:5432/postgres

SESSION_SECRET=test-secret-at-least-32-characters-long-for-ci-only
SESSION_COOKIE_NAME=gumes.sid
SESSION_MAX_AGE_MS=604800000

CORS_ORIGIN=http://localhost:5173

# Mock Nominatim local (voir tests/helpers/nominatim-mock.js)
NOMINATIM_USER_AGENT=gumes-marketplace-test/1.0
NOMINATIM_BASE_URL=http://127.0.0.1:4599

# Rate-limit désactivé pour les tests
RATELIMIT_LOGIN_MAX=100000
RATELIMIT_LOGIN_WINDOW_MS=60000

# Délais de paiement réduits (normalement 1500/5000ms)
PAIEMENT_DELAY_SUCCESS_MS=10
PAIEMENT_DELAY_ERROR_MS=10
