# ────────────────────────────────────────────────────────────
#  gumes marketplace — fichier d'environnement (exemple)
#  Copier en `.env` et ajuster. NE JAMAIS committer `.env`.
# ────────────────────────────────────────────────────────────

# ─── PostgreSQL / PostGIS ───────────────────────────────────
POSTGRES_USER=gumes
POSTGRES_PASSWORD=change-me-in-local
POSTGRES_DB=gumes_marketplace
POSTGRES_PORT=5432

# URL composée utilisée par `pg` et node-pg-migrate
DATABASE_URL=postgres://gumes:change-me-in-local@localhost:5432/gumes_marketplace

# ─── Adminer (interface d'admin DB en dev) ──────────────────
ADMINER_PORT=8080

# ─── Serveur Node / Express ─────────────────────────────────
NODE_ENV=development
PORT=3000
PUBLIC_URL=http://localhost:3000

# Secret de session — générer avec : node -e "console.log(crypto.randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-64-char-hex-string
SESSION_COOKIE_NAME=gumes.sid
SESSION_MAX_AGE_MS=604800000   # 7 jours

# CORS : origine du front (Vite dev) — restreinte
CORS_ORIGIN=http://localhost:5173

# ─── Front-end (Vite) ───────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3000/api

# ─── Géocodage ──────────────────────────────────────────────
# Nominatim exige un User-Agent identifiant l'application.
NOMINATIM_USER_AGENT=gumes-marketplace/1.0 (contact@example.com)
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# ─── Rate-limit (développement : tolérant ; prod : à resserrer) ──
RATELIMIT_LOGIN_MAX=5
RATELIMIT_LOGIN_WINDOW_MS=60000
