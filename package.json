{
  "name": "gumes-marketplace",
  "version": "0.1.0",
  "private": true,
  "description": "gumes marketplace — plateforme de vente de produits locaux (Technologies Web IAI1).",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "start": "npm --workspace server start",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset:schema": "node scripts/reset-schema.js",
    "db:migrate": "npm --workspace server run db:migrate",
    "db:migrate:down": "npm --workspace server run db:migrate:down",
    "db:seed": "npm --workspace server run db:seed",
    "db:prep": "npm run db:reset:schema && npm run db:migrate && npm run db:seed && npm run images:download && npm run images:import",
    "db:reset": "npm run db:prep",
    "images:download": "node db/seed-images/download.js",
    "images:import": "npm --workspace server run images:import",
    "test": "npm --workspace server run test"
  },
  "engines": {
    "node": ">=20"
  }
}
