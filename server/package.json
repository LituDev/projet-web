{
  "name": "@gumes/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "db:migrate": "dotenv -e ../.env -- node-pg-migrate -m ../db/migrations --migrations-schema public up",
    "db:migrate:down": "dotenv -e ../.env -- node-pg-migrate -m ../db/migrations --migrations-schema public down",
    "db:seed": "node ../db/seeds/index.js",
    "test": "dotenv -e ../.env.test -- node --test --test-concurrency=1 tests/run.test.js",
    "lint": "eslint src"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "connect-pg-simple": "^10.0.0",
    "cors": "^2.8.6",
    "csurf": "^1.11.0",
    "dotenv": "^17.4.2",
    "ejs": "^5.0.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "dotenv-cli": "^11.0.0",
    "node-pg-migrate": "^8.0.4",
    "pino-pretty": "^13.0.0",
    "supertest": "^7.2.2"
  }
}
